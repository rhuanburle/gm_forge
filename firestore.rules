rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ────────────────────────────────────────────────────

    // Only authenticated, non-anonymous users can access their own data
    function isAuthed() {
      return request.auth != null && !request.auth.token.firebase.sign_in_provider.matches('anonymous');
    }

    function isOwner(uid) {
      return isAuthed() && request.auth.uid == uid;
    }

    // ── User data ───────────────────────────────────────────────────────────

    // Adventures: /users/{uid}/adventures/{adventureId}
    match /users/{uid}/adventures/{adventureId} {
      allow read: if isOwner(uid);
      allow write: if isOwner(uid)
        && request.resource.data.keys().hasAll(['adventure', 'updatedAt', 'version'])
        && request.resource.data.version is int;
      allow delete: if isOwner(uid);
    }

    // Campaigns: /users/{uid}/campaigns/{campaignId}
    match /users/{uid}/campaigns/{campaignId} {
      allow read: if isOwner(uid);
      allow write: if isOwner(uid)
        && request.resource.data.keys().hasAll(['campaign', 'updatedAt']);
      allow delete: if isOwner(uid);
    }

    // ── Public pages (player-facing, no auth required to read) ──────────

    match /public_pages/{shareId} {
      // Anyone can read active public pages
      allow read: if true;
      // Only the owning GM can create/update/delete
      allow create: if isAuthed() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthed() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthed() && resource.data.userId == request.auth.uid;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
